{
	"name": "trakit",
	"version": "0.2.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"migrate:up": "node scripts/migrate-sqlite.mjs up",
		"migrate:down": "node scripts/migrate-sqlite.mjs down",
		"migrate:create": "node scripts/migrate-sqlite.mjs create",
		"generate:notification-keys": "node scripts/generate-notification-keys.mjs"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@iconify/svelte": "^5.2.2",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/luxon": "^3.7.2",
		"@types/node": "^26.0.1",
		"@types/node-cron": "^3.0.11",
		"@types/nodemailer": "^8.0.1",
		"@types/web-push": "^3.6.4",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"autoprefixer": "^10.5.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"postcss": "^8.5.16",
		"prettier": "^3.9.3",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"better-sqlite3": "^12.11.1",
		"html2canvas": "^1.4.1",
		"luxon": "^3.7.2",
		"node-cron": "^4.5.0",
		"nodemailer": "^9.0.1",
		"web-push": "^3.6.7"
	},
	"overrides": {
		"cookie": "^0.7.2",
		"glob": "^13.0.6"
	}
}
